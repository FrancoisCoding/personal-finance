# Database
PRISMA_DATABASE_URL="postgresql://username:password@localhost:5432/finance_app"
DATABASE_URL="postgresql://username:password@localhost:5432/finance_app"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# OpenRouter (hosted AI)
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="openrouter/free"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Distributed rate limiting (optional, recommended in production)
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Stripe billing
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxx"
STRIPE_PRICE_BASIC_MONTHLY="price_xxxxxxxxx_basic"
STRIPE_PRICE_PRO_MONTHLY="price_xxxxxxxxx_pro"

# Admin portal
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-strong-password"
ADMIN_SESSION_SECRET="replace-with-long-random-secret"

# Teller (bank connections)
NEXT_PUBLIC_TELLER_APPLICATION_ID="your-teller-application-id"
NEXT_PUBLIC_TELLER_ENV="sandbox"
TELLER_ENV="sandbox"
TELLER_CERT_PATH="/path/to/teller-cert.pem"
TELLER_KEY_PATH="/path/to/teller-key.pem"

# Ads (public pages only)
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_ADSENSE_SLOT_LANDING_HERO="1234567890"
NEXT_PUBLIC_ADSENSE_SLOT_LANDING_FOOTER="2345678901"
NEXT_PUBLIC_ADSENSE_SLOT_SUPPORT="3456789012"

# Email (optional)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-email-password"
EMAIL_FROM="noreply@yourdomain.com" 
